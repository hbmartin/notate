<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".CanvasActivity">

    <!-- 1. Canvas (Bottom Layer) -->
    <com.alexdremov.notate.ui.OnyxCanvasView
        android:id="@+id/canvasView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 1.5 Cursor Overlay -->
    <com.alexdremov.notate.ui.CursorView
        android:id="@+id/cursorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 2. Toolbar (Middle Layer) -->
    <!-- Initial margins handled by Coordinator -->
    <com.alexdremov.notate.ui.DraggableLinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:elevation="6dp"
        android:padding="0dp" />

    <!-- 2.5 Minimap -->
    <com.alexdremov.notate.ui.MinimapView
        android:id="@+id/minimapView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="6dp" />

    <!-- 3. Scrim (Overlay Layer) -->
    <View
        android:id="@+id/sidebar_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true" />

    <!-- 4. Sidebar (Top Layer) -->
    <FrameLayout
        android:id="@+id/settings_sidebar_container"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#FFFFFF"
        android:foreground="@drawable/bg_sidebar_foreground"
        android:elevation="16dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- 4.5 Selection Actions Container (Directly above canvas, below sidebar) -->
    <FrameLayout
        android:id="@+id/selection_actions_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- 5. Error Banner (Notification Layer) -->
    <com.alexdremov.notate.ui.ErrorBannerView
        android:id="@+id/errorBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp" />

</FrameLayout>
